# =========================================================
# OS / FILE SYSTEM JUNK
# =========================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msm
*.msp

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# Editor swap/backup
*.swp
*.swo
*.tmp
*.temp
*.bak
*.orig

# =========================================================
# ENV & SECRETS  (jangan commit kredensial!)
# =========================================================
.env
.env.*
!.env.example
!.env.testing.example

# Vagrant / VM
.vagrant
Vagrantfile

# Docker overrides (opsional)
docker-compose.override.yml

# =========================================================
# CODEIGNITER 4 WRITABLE (simpan hanya placeholder index.html)
# =========================================================
writable/cache/*
!writable/cache/index.html

writable/logs/*
!writable/logs/index.html

writable/session/*
!writable/session/index.html

writable/uploads/*
!writable/uploads/index.html

writable/debugbar/*
!writable/debugbar/index.html

# File log umum
php_errors.log
*.log

# =========================================================
# DEPENDENCIES & ARTIFACTS
# =========================================================
# Composer
/vendor/
composer.phar
# (Catatan: **JANGAN** ignore composer.lock. Biarkan TERCOMMIT untuk build reproducible.)

# Node / Front-end (opsional jika ada)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build outputs (opsional, sesuai tool yang dipakai)
dist/
build/
coverage/
.nyc_output/

# Vite / Laravel Mix style (kalau dipakai bersama CI4)
.vite/
public/build/
public/hot

# =========================================================
# TESTS & QA
# =========================================================
# PHPUnit
.phpunit.result.cache
tests/coverage*
/phpunit*.xml          # ignore file lokal; tetap commit phpunit.xml.dist bila ada
phpunit                # jangan commit binary phpunit lokal

# Static analysis / linters cache
.php-cs-fixer.cache
.phpcs-cache
.phpstorm.meta.php
.phpstan/
.psalm/
.psalm-cache/

